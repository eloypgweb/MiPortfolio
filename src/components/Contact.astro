                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div class="method-info">
              <span class="method-label" data-i18n="contact.email">Email</span>
              <span class="method-value">eloypg.web@gmail.com</span>
            </div>
          </a>
          
          <a href="https://es.linkedin.com/in/eloy-perez-gomez" target="_blank" rel="noopener noreferrer" class="contact-method">
            <div class="method-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
